{
  "name": "@remote-control/desktop",
  "version": "0.2.10",
  "private": true,
  "description": "RemoteControl desktop app",
  "author": "RemoteControl",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "dev:server-app": "node scripts/run-electron-vite.mjs dev host",
    "dev:client-app": "node scripts/run-electron-vite.mjs dev viewer",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build": "npm run typecheck && electron-vite build",
    "build:win": "npm run build && electron-builder --win nsis",
    "prepare:backend": "node scripts/copy-backend.mjs",
    "prepare:release": "node scripts/prepare-release.mjs",
    "build:server-app": "npm run build --workspace @remote-control/shared && npm run build --workspace @remote-control/server && npm run prepare:backend && cross-env REMOTE_CONTROL_APP_MODE=host npm run build && electron-builder --config electron-builder.server.yml --win nsis --publish never",
    "build:client-app": "cross-env REMOTE_CONTROL_APP_MODE=viewer npm run build && electron-builder --config electron-builder.client.yml --win nsis --publish never",
    "build:apps": "npm run build:server-app && npm run build:client-app",
    "build:release": "npm run build:apps && npm run prepare:release",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "build": {
    "appId": "dev.remote-control.desktop",
    "productName": "RemoteControl",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@remote-control/shared": "0.2.10",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.1.0",
    "electron": "39.8.9",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "optionalDependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6"
  }
}
